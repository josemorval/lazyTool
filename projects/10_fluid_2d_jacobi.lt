lazyTool_project 1

camera_fps 0 0 3 3.1415927 0 0.95 0.01 50

dirlight -3 4 2 0 0 0 1 1 1 1 64 64 0.1 15 4 4

resources

resource value float Viscosity 0 0 0 0 0.992 0 0 0
resource value float Force 0 0 0 0 1.4 0 0 0
resource value float Radius 0 0 0 0 0.18 0 0 0
resource value float DisplayScale 0 0 0 0 3.5 0 0 0
resource mesh_primitive fs_tri fullscreen_triangle
resource shader_cs fluid_inject shaders/fluid_inject.hlsl
resource shader_cs fluid_advect shaders/fluid_advect.hlsl
