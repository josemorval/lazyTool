resource shader_cs fluid_gradsub shaders/fluid_gradsub.hlsl
resource shader_vsps fluid_visualize shaders/fluid_visualize.hlsl
resource render_texture vel_a 0 0 34 1 1 1 0 2
resource render_texture vel_b 0 0 34 1 1 1 0 2
resource render_texture divergence 0 0 54 1 1 1 0 2
resource render_texture pressure_a 0 0 54 1 1 1 0 2
resource render_texture pressure_b 0 0 54 1 1 1 0 2

